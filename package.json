{
  "name": "eve-at-draft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "data:fetch": "tsx ./tools/data-pipeline/cli.ts fetch 2025",
    "data:build": "tsx ./tools/data-pipeline/cli.ts build 2025",
    "data:validate": "tsx ./tools/data-pipeline/cli.ts validate 2025",
    "data:refresh": "tsx ./tools/data-pipeline/cli.ts refresh 2025",
    "tools:validate": "tsx ./tools/validate-data.ts",
    "build": "node ./tools/check-node-version.mjs && vite build",
    "preview": "vite preview"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.21",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/opencc-js": "^1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.1",
    "opencc-js": "^1.0.5",
    "sass": "^1.81.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "yarn@4.9.4"
}
